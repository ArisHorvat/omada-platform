{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Omada API",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build api",
            "program": "${workspaceFolder}/src/backend/omada.api/bin/Debug/net8.0/omada.api.dll", // CHECK THIS PATH
            "args": [],
            "cwd": "${workspaceFolder}/src/backend/omada.api", // CHECK THIS PATH
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/swagger"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        }
    ]
}
